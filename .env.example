# ========================================
# VK Bot — Environment Variables
# ========================================

# === VK ===
VK_TOKEN=your_vk_bot_token_here

# === Admin ===
ADMIN_ID=27260796

# === Supabase (Database) ===
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_or_service_key

# === Gemini AI (можно несколько ключей через запятую) ===
GEMINI_API_KEYS=your_gemini_key1,your_gemini_key2,your_gemini_key3

# === Redis (Upstash) ===
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# === Sentry (мониторинг ошибок) ===
SENTRY_DSN=your_sentry_dsn_here

# === Server ===
PORT=10000

# ========================================
# Опциональные переменные
# ========================================

# REDIS_URL=redis://...   # если используешь другой Redis
# LOG_LEVEL=INFO