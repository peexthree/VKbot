# --- VK API CONFIG ---
# Токен сообщества (Настройки -> Работа с API)
VK_TOKEN=vk1.a.xxxxxxxxxxxxxxxxxxxxxx

# Код подтверждения сервера (Настройки -> Callback API)
VK_CONFIRMATION_CODE=xxxxxx

# Секретный ключ (Настройки -> Callback API)
VK_SECRET_KEY=xxxxxxxxxxxx

# ID администратора (для доступа к консоли /admin)
ADMIN_ID=12345678


# --- AI CONFIG (Google Gemini) ---
# Ключи через запятую для ротации (https://aistudio.google.com/)
GEMINI_API_KEYS=key1,key2,key3


# --- DATABASE CONFIG (Supabase) ---
# URL проекта (Settings -> API)
SUPABASE_URL=https://your-project.supabase.co

# Ключ anon/public (Settings -> API)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# --- CACHE CONFIG (Upstash Redis) ---
# URL для подключения (rediss://...)
UPSTASH_REDIS_URL=rediss://default:password@your-db.upstash.io:6379


# --- SYSTEM CONFIG ---
# Порт сервера (для Render ставьте 10000)
PORT=10000

# Режим работы (true - Webhooks, false - Long Polling)
USE_WEBHOOKS=true

# Sentry DSN для мониторинга ошибок (необязательно)
SENTRY_DSN=https://xxxxxxxx@o0.ingest.sentry.io/xxxxxxx
SENTRY_ENV=production

# Секретный ключ для подписи внутренних данных (любая строка)
PAYMENT_SECRET=your_random_secret_string
